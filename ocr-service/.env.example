# Python OCR service environment
# Copy to .env — never commit .env

# API key that Java sends in X-API-Key header (leave empty to disable auth in dev)
PYTHON_API_KEY=replace_with_strong_random_key

# Comma-separated origins allowed to call this service directly
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000

# SQLite (dev) or PostgreSQL (prod) for OCR cache
DATABASE_URL=sqlite:///./ocr_cache.db

# Log level
LOG_LEVEL=INFO
