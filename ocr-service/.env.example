# Toggle local Ollama extractor.
# Ollama suggestions are advisory only; Java rules and reviewers decide.
USE_AI_EXTRACTION=false
AI_PROVIDER=ollama
AI_MODEL=llama3.1:8b
OLLAMA_BASE_URL=http://127.0.0.1:11434
CONFIDENCE_THRESHOLD=0.95

# Feedback storage
# Leave DATABASE_URL empty to use SQLite FEEDBACK_DB_PATH.
DATABASE_URL=
FEEDBACK_DB_PATH=logs/feedback.sqlite3

# OCR tuning
OCR_TIMEOUT=120
OCR_RETRIES=2
