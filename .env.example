# ============================================================
# Apprisal QC Platform — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# ── Database ─────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ardurApprisal
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password

# ── Java Spring Boot ─────────────────────────────────────────
# JWT secret: generate with: openssl rand -hex 32
JWT_SECRET=replace_with_64_char_hex_string

# Admin account (created on first boot by AdminSeeder)
ADMIN_EMAIL=admin@yourcompany.com
ADMIN_PASSWORD=ChangeMe123!

# Session cookies — set true when behind HTTPS in production
COOKIE_SECURE=false

# ── Python OCR Service ────────────────────────────────────────
# Shared API key — must match on both Java (PYTHON_API_KEY) and Python side
PYTHON_API_KEY=replace_with_strong_random_key

# URL Java uses to reach the Python service
OCR_SERVICE_URL=http://localhost:5001
OCR_TIMEOUT=180
OCR_RETRIES=2

# Storage path for uploaded ZIP files
STORAGE_PATH=./uploads

# ── Python service .env (ocr-service/.env) ───────────────────
# Python reads these directly; repeat relevant vars above:
# PYTHON_API_KEY=same_as_above
# ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000
# DATABASE_URL=sqlite:///./ocr_cache.db  (or PostgreSQL URL)

# ── Frontend (frontend/.env.local) ───────────────────────────
# NEXT_PUBLIC_JAVA_URL=http://localhost:8080
