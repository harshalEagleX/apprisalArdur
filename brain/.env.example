# Frontend Next.js app URL.
APP_BASE_URL=http://localhost:3000

# Java/Spring backend URL.
JAVA_BASE_URL=http://localhost:8080

# Role credentials used by the simulation agents.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
REVIEWER_USERNAME=reviewer
REVIEWER_PASSWORD=reviewer

# Optional AI mode: heuristic, langchain, or openai.
# When OPENAI_API_KEY is absent, the harness uses deterministic heuristics.
AI_PROVIDER=heuristic
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Upload scenario data.
# Point this at a real ZIP accepted by the backend. Leave empty to skip upload and use existing batches.
BATCH_ZIP_PATH=
CLIENT_ID=

# Runtime tuning.
HEADLESS=true
SLOW_MO_MS=0
SCENARIO_TIMEOUT_MS=900000
QC_TIMEOUT_MS=600000
REVIEW_TIMEOUT_MS=600000
